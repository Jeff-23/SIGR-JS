generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Restaurante {
  id            Int        @id @default(autoincrement())
  nombre        String     @db.VarChar(100)
  nit           String     @unique @db.VarChar(20)
  direccion     String?    @db.VarChar(200)
  telefono      String?    @db.VarChar(20)
  correo        String?    @db.VarChar(150)
  estado        Boolean    @default(true)
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt
  sucursales    Sucursal[]
}

model Sucursal {
  id            Int         @id @default(autoincrement())
  nombre        String      @db.VarChar(100)
  direccion     String?     @db.VarChar(200)
  telefono      String?     @db.VarChar(20)
  estado        Boolean     @default(true)
  creadoEn      DateTime    @default(now())
  restauranteId Int
  restaurante   Restaurante @relation(fields: [restauranteId], references: [id])
  usuarios      Usuario[]
  zonas         Zona[]
  categorias    Categoria[]
  articulos     Articulo[]  // <-- RELACIÓN FASE 4 AÑADIDA
}

model Rol {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique @db.VarChar(50)
  descripcion String?   @db.Text
  usuarios    Usuario[]
}

model Usuario {
  id         Int       @id @default(autoincrement())
  nombres    String    @db.VarChar(100)
  apellidos  String    @db.VarChar(100)
  email      String    @unique @db.VarChar(150)
  password   String    @db.VarChar(255)
  activo     Boolean   @default(true)
  rolId      Int
  sucursalId Int?
  creadoEn   DateTime  @default(now())
  rol        Rol       @relation(fields: [rolId], references: [id])
  sucursal   Sucursal? @relation(fields: [sucursalId], references: [id])
  pedidos    Pedido[]
}

model Zona {
  id         Int      @id @default(autoincrement())
  nombre     String   @db.VarChar(50)
  estado     Boolean  @default(true)
  creadoEn   DateTime @default(now())
  sucursalId Int
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])
  mesas      Mesa[]
}

model Mesa {
  id         Int      @id @default(autoincrement())
  numero     String   @db.VarChar(10)
  capacidad  Int      @default(4)
  situacion  String   @default("LIBRE")
  estado     Boolean  @default(true)
  creadoEn   DateTime @default(now())
  zonaId     Int
  zona       Zona     @relation(fields: [zonaId], references: [id])
  pedidos    Pedido[]
}

model Categoria {
  id         Int      @id @default(autoincrement())
  nombre     String   @db.VarChar(50)
  estado     Boolean  @default(true)
  creadoEn   DateTime @default(now())
  sucursalId Int
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])
  productos  Producto[]
}

model Producto {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.VarChar(100)
  descripcion String?  @db.Text
  precio      Decimal  @db.Decimal(10, 2)
  stock       Int?
  estado      Boolean  @default(true)
  creadoEn    DateTime @default(now())
  categoriaId Int
  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  detalles    DetallePedido[]
  recetas     Receta[] // <-- RELACIÓN FASE 4 AÑADIDA
}

model Pedido {
  id        Int      @id @default(autoincrement())
  total     Decimal  @db.Decimal(10, 2)
  creadoEn  DateTime @default(now())
  mesaId    Int
  usuarioId Int
  mesa      Mesa     @relation(fields: [mesaId], references: [id])
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  detalles  DetallePedido[]
  factura   Factura? //
}

model DetallePedido {
  id         Int      @id @default(autoincrement())
  cantidad   Int
  subtotal   Decimal  @db.Decimal(10, 2)
  pedidoId   Int
  productoId Int
  pedido     Pedido   @relation(fields: [pedidoId], references: [id])
  producto   Producto @relation(fields: [productoId], references: [id])
}

// ==========================================
// FASE 4: INVENTARIOS Y RECETAS
// ==========================================

model Articulo {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.VarChar(100)
  unidad      String   @db.VarChar(20) // ej: gramos, mililitros, unidades
  costoUnidad Decimal  @db.Decimal(10, 2)
  stock       Decimal  @db.Decimal(10, 2)
  estado      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  // Relaciones
  sucursalId  Int
  sucursal    Sucursal @relation(fields: [sucursalId], references: [id])
  recetas     Receta[]
}

model Receta {
  id          Int      @id @default(autoincrement())
  cantidad    Decimal  @db.Decimal(10, 2) // Cuánto de este artículo usa el producto
  
  // Relaciones
  productoId  Int
  articuloId  Int
  producto    Producto @relation(fields: [productoId], references: [id])
  articulo    Articulo @relation(fields: [articuloId], references: [id])

  // Restricción: Un producto no puede tener el mismo artículo dos veces en su receta
  @@unique([productoId, articuloId]) 
}

// ==========================================
// FASE 5: FACTURACIÓN Y PAGOS (DIAN)
// ==========================================

model MetodoPago {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.VarChar(50) // Ej: Efectivo, Tarjeta, Nequi, DaviPlata
  activo      Boolean  @default(true)
  pagos       Pago[]
}

model Factura {
  id               Int      @id @default(autoincrement())
  numero           String   @unique @db.VarChar(50) // Prefijo + consecutivo (Ej: SET-1)
  total            Decimal  @db.Decimal(10, 2)
  cufe             String?  @db.VarChar(150) // Código Único de Factura Electrónica (DIAN)
  qrCode           String?  @db.Text
  resolucionDian   String?  @db.VarChar(100)
  estado           String   @default("EMITIDA") // EMITIDA, ANULADA
  creadoEn         DateTime @default(now())

  // Relaciones
  pedidoId         Int      @unique
  pedido           Pedido   @relation(fields: [pedidoId], references: [id])
  pagos            Pago[]
}

model Pago {
  id             Int        @id @default(autoincrement())
  monto          Decimal    @db.Decimal(10, 2)
  creadoEn       DateTime   @default(now())

  // Relaciones
  facturaId      Int
  metodoPagoId   Int
  factura        Factura    @relation(fields: [facturaId], references: [id])
  metodoPago     MetodoPago @relation(fields: [metodoPagoId], references: [id])
}